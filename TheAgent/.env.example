# Xians Platform Configuration
XIANS-SERVER-URL=
XIANS-API-KEY=
# Optional: display name used when registering this agent with the Xians platform
# (defaults to "Xianix AI-DLC Agent"). Workflow type names are unaffected.
#AGENT-NAME=Xianix AI-DLC Agent
# Docker executor image (defaults to xianix-executor:latest)
EXECUTOR-IMAGE=xianix-executor:latest
CONTAINER-MEMORY-MB=1024   # Memory limit per container in MB
CONTAINER-CPU-COUNT=1      # CPU cores per container (fractional allowed, e.g. 0.5)
CONTAINER-EXECUTION-TIMEOUT-SECONDS=900  # Hard wall-clock cap per container run; killed when exceeded (default 15 min)
# Optional token backstop: host-wide default cap on agent turns, applied by the executor
# only when a rule doesn't set its own `max-turns`. 0 (default) = no cap (only the wall-clock
# timeout applies). Per-execution `max-turns` in rules.json always wins.
#EXECUTOR-DEFAULT-MAX-TURNS=0
# Optional hybrid repo context (cost lever): when enabled, the executor appends an
# LLM-authored "Architecture & conventions" narrative to the auto-generated CLAUDE.md (on top
# of the always-on deterministic facts + symbol map). It runs only on a context cache miss
# (once per repo HEAD change), is skipped when the repo ships its own CLAUDE.md, and silently
# falls back to the deterministic-only CLAUDE.md on any failure. Off by default. A tenant can
# override per rule-set with an `XIANIX-CONTEXT-LLM` with-envs entry in rules.json.
#EXECUTOR-CONTEXT-LLM=false
# Model used for that narrative pass (cheapest tier by default so context never becomes a cost line).
#EXECUTOR-CONTEXT-LLM-MODEL=claude-haiku-4-5

# Optional fallback for the supervisor + executor Anthropic API key.
# Resolution order on the supervisor's first chat message and on every container
# launch: the rule-set-level `with-envs` entry in rules.json wins, then this host
# env, then empty (which surfaces a clear "missing API key" error to the user on
# first chat and skips seeding the executor container env). Leave commented out
# if you manage the key entirely from rules.json.
#ANTHROPIC-API-KEY=
# Optional: Claude model override for the SUPERVISOR chat agent (Xians SDK) only.
# Does NOT affect the executor container — set the per-execution `model` field in
# rules.json (or an `ANTHROPIC-MODEL` with-envs entry) to tier the executor's model.
#ANTHROPIC-DEPLOYMENT-NAME=claude-haiku-4-5

# Executor model tiering (cost lever)
# ───────────────────────────────────
# The executor (Executor/execute_plugin.py) picks its primary model from, in order:
#   1. the per-execution `model` field in rules.json  -> XIANIX-MODEL env
#   2. an `ANTHROPIC-MODEL` with-envs entry in rules.json (zero-code fallback)
#   3. the Claude Code SDK default (Sonnet-class) when neither is set
# Background/side-query work always routes to a cheap Haiku-class model
# (ANTHROPIC_DEFAULT_HAIKU_MODEL, defaulted by the executor to claude-haiku-4-5).
# These are set per-tenant via rules.json, not here — this block is documentation only.
#
# Session reuse (opt-in cost lever): when enabled, back-to-back runs against the same
# conversation (repo + PR/issue) resume the prior Claude Code session instead of rebuilding
# context, and Claude's session store is persisted on the volume via CLAUDE_CONFIG_DIR.
# Best-effort — a failed resume falls back to a fresh run. Enable per execution block in
# rules.json with the first-class field "resume-sessions": true.
#
# Cost budget (cost lever): set the per-execution `max-budget-usd` field in rules.json to
# cap a single run's spend. The executor passes it to the Claude Code SDK (max_budget_usd),
# which aborts the run once exceeded; metrics chart the configured budget and an over-budget flag.